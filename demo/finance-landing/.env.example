# Sao chép file này thành .env.local rồi điền giá trị thật.
# URL Web App của Google Apps Script dùng để ghi lead vào Google Sheet.
# KHÔNG commit .env.local (đã nằm trong .gitignore).
SHEET_WEBHOOK_URL=

# Khoá bí mật ký time-token chống bot (HMAC). Đặt chuỗi ngẫu nhiên dài ở prod.
# Nếu để trống, code dùng giá trị dev mặc định KHÔNG an toàn cho production.
FORM_SECRET=
